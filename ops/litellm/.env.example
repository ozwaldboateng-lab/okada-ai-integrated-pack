OKADA_BASE_URL=http://okada-kernel:8080
OKADA_SHARED_TOKEN=change-me
OKADA_POLICY_PROFILE=default
OKADA_DETERMINISTIC_MODE=true
OKADA_ROUTE_MAP_PATH=/app/examples/litellm/route_map.json

OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_API_KEY=replace-me
LITELLM_MASTER_KEY=replace-me
CHEAP_MODEL_NAME=openai/gpt-4o-mini
STRONG_MODEL_NAME=openai/gpt-4.1

LITELLM_IMAGE=replace-with-your-litellm-image
LITELLM_PROXY_PORT=4000

PYTHONPATH=/app/apps/okada-kernel-service

    "spec_id",
    "adapter_type",
    "suite_name",
    "summary",
    "results"
  ],
  "properties": {
    "profile_name": {
      "type": "string"
    },
    "spec_id": {
      "type": "string"
    },
    "adapter_type": {
      "type": "string"
    },
    "suite_name": {
      "type": "string"
    },
    "proposal_source": {
      "type": "string"
    },
    "summary": {
      "type": "object"
    },
    "results": {
      "type": "array"
    }
  }
}

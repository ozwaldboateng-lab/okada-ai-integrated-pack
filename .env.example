OKADA_AUDIT_DIR=./data/audit
OKADA_AUDIT_BACKEND=jsonl
OKADA_DEFAULT_POLICY=default
OKADA_SERVICE_PORT=8080
OKADA_SERVICE_NAME=okada-kernel
OKADA_REQUIRE_AUTH=false
OKADA_SHARED_TOKEN=change-me
OKADA_BASE_URL=http://localhost:8080
OKADA_POLICY_THRESHOLD_T_CLEAN=0.45
OKADA_POLICY_THRESHOLD_T_CONTAM=0.95
OKADA_POLICY_THRESHOLD_HIGH_RISK_BONUS=0.15
